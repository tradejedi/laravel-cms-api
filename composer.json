{
    "name": "coolmacjedi/laravel-cms-api",
    "description": "Token-scoped REST API for managing CMS content (posts, blocks, tables, menus, media) via external AI agents.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "laravel/sanctum": "^4.0",
        "dedoc/scramble": "^0.13"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "CoolMacJedi\\LaravelCmsApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CoolMacJedi\\LaravelCmsApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CoolMacJedi\\LaravelCmsApi\\CmsApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
